root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = tab
indent_size = 2

[*.py]
indent_style = space
indent_size = 4

[*.{sh,zsh,bash,fish,sbatch,profile}]
indent_style = tab
indent_size = 4

[*.{yaml,yml}]
indent_style = space
indent_size = 2

[*.{diff,md}]
trim_trailing_whitespace = false
